<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Protocol: Birthday_Mahu_2026</title>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.5.1/dist/confetti.browser.min.js"></script>
    <style>
        :root {
            --ted-red: #E62B1E;
            --ted-orange: #FF8C00;
            --dark-surface: #111111;
        }

        body {
            margin: 0;
            background-color: var(--dark-surface);
            color: white;
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            overflow: hidden;
        }

        /* Giao diện Gradient Cam-Đỏ rực rỡ */
        .main-container {
            position: relative;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at center, var(--ted-red) 0%, #330000 100%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
        }

        .content-box {
            background: rgba(0, 0, 0, 0.6);
            padding: 40px;
            border-radius: 4px; /* TED style: vuông vức, chuyên nghiệp */
            border-left: 5px solid var(--ted-orange);
            box-shadow: 0 20px 50px rgba(0,0,0,0.5);
            max-width: 600px;
        }

        h1 {
            font-size: 3.5rem;
            margin: 0;
            letter-spacing: -1px;
            background: linear-gradient(to right, #ffffff, var(--ted-orange));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .target-name {
            color: var(--ted-orange);
            font-weight: bold;
            font-size: 1.2rem;
            margin-bottom: 20px;
            display: block;
        }

        .message {
            font-size: 1.4rem;
            line-height: 1.6;
            margin: 25px 0;
            font-weight: 300;
        }

        .function-terminal {
            background: #000;
            padding: 15px;
            border-radius: 4px;
            font-family: 'Courier New', monospace;
            font-size: 0.85rem;
            text-align: left;
            color: #00FF00;
            margin-top: 20px;
            border: 1px solid #333;
        }

        .footer-brand {
            margin-top: 40px;
            font-weight: bold;
            letter-spacing: 2px;
            color: rgba(255,255,255,0.7);
        }

        .action-btn {
            background: var(--ted-red);
            color: white;
            border: none;
            padding: 15px 40px;
            font-size: 1rem;
            font-weight: bold;
            cursor: pointer;
            margin-top: 20px;
            transition: all 0.3s;
        }

        .action-btn:hover {
            background: var(--ted-orange);
            transform: translateY(-3px);
        }
    </style>
</head>
<body>

<div class="main-container">
    <div class="content-box">
        <span class="target-name">[ STATUS: CELEBRATION_MODE_ACTIVE ]</span>
        <h1>HAPPY BIRTHDAY, MAHU!</h1>
        
        <p class="message">
            "Chúc Mahu tuổi mới rực rỡ như sắc đỏ của TEDx, <br>
            luôn đầy ắp những ý tưởng đột phá và năng lượng <br>
            để cùng <strong>coreteamtedx25</strong> chinh phục mọi giới hạn!"
        </p>

        <div class="function-terminal" id="terminal">
            > Initializing birthday_logic.exe...<br>
            > Checking Mahu's happiness levels... 100%<br>
            > Deploying love from coreteamtedx25...<br>
            > <span style="color: var(--ted-orange);">Status: Success.</span>
        </div>

        <button class="action-btn" onclick="triggerImpact()">KÍCH HOẠT NIỀM VUI</button>

        <div class="footer-brand">
            FROM "CORETEAMTEDX25" WITH ❤️
        </div>
    </div>
</div>

<script>
    function triggerImpact() {
        // Hiệu ứng pháo hoa cực mạnh tone cam đỏ
        const duration = 3 * 1000;
        const end = Date.now() + duration;

        (function frame() {
            confetti({
                particleCount: 5,
                angle: 60,
                spread: 55,
                origin: { x: 0 },
                colors: ['#E62B1E', '#FF8C00', '#FFFFFF']
            });
            confetti({
                particleCount: 5,
                angle: 120,
                spread: 55,
                origin: { x: 1 },
                colors: ['#E62B1E', '#FF8C00', '#FFFFFF']
            });

            if (Date.now() < end) {
                requestAnimationFrame(frame);
            }
        }());
        
        document.getElementById('terminal').innerHTML += "<br>> Burst_Effect: Executed.";
    }

    // Tự động chạy lần đầu
    window.onload = () => {
        setTimeout(triggerImpact, 500);
    };
</script>

</body>
</html>
